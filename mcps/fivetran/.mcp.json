{
  "mcpServers": {
    "fivetran": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/fivetran/fivetran-mcp", "fivetran-mcp"],
      "env": {
        "FIVETRAN_ALLOW_WRITES": "${user_config.fivetran_allow_writes}",
        "FIVETRAN_API_KEY": "${user_config.fivetran_api_key}",
        "FIVETRAN_API_SECRET": "${user_config.fivetran_api_secret}"
      }
    }
  }
}
